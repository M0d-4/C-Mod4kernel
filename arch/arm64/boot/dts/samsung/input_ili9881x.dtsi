&tlmm {
	ili9881x_tsp_int_active: ili9881x_tsp_int_active {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,34, FUNC_INPUT_WAKEUP, PULL_NONE, DRV_LV4);
	};

	ili9881x_int_sleep: ili9881x_tsp_int_sleep {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,34, FUNC_INPUT, PULL_DOWN, DRV_LV1);
	};
};

&tlmm {
	ili9881x_tsp_rst_active: ili9881x_tsp_rst_active {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,81, FUNC_INPUT, PULL_DOWN, DRV_LV1);
	};

	ili9881x_tsp_rst_sleep: ili9881x_tsp_rst_sleep {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,81, FUNC_INPUT, PULL_DOWN, DRV_LV1);
	};
};

&tlmm {
	ili9881x_tsp_cs_active: ili9881x_tsp_cs_active {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,3, FUNC_OUTPUT_HIGH, PULL_UP, DRV_LV3);
	};

	ili9881x_tsp_cs_sleep: ili9881x_tsp_cs_sleep {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,3, FUNC_OUTPUT_LOW, PULL_DOWN, DRV_LV3);
	};
};

&qupv3_se0_spi {
	status = "ok";
	num-cs = <1>;

	tsp_ilitek: ilitek@3 {
		spi-max-frequency = <9600000>;
		compatible = "ilitek,ili9881x-spi";
		reg = <3>;
		status = "okay";

		pinctrl-names = "default", "on_state", "off_state";
		pinctrl-0 = <&ili9881x_tsp_int_active &ili9881x_tsp_rst_active>;
		pinctrl-1 = <&ili9881x_tsp_int_active &ili9881x_tsp_rst_active &ili9881x_tsp_cs_active>;
		pinctrl-2 = <&ili9881x_int_sleep &ili9881x_tsp_rst_sleep &ili9881x_tsp_cs_sleep>;

		ilitek,reset-gpio = <SEC_GPIO_REF(AP,tlmm,81) 0x00>;
		ilitek,irq-gpio = <SEC_GPIO_REF(AP,tlmm,34) 0x2002>;
		ilitek,cs-gpio = <SEC_GPIO_REF(AP,tlmm,3) 0>;

		ilitek,irq-on-state = <0>;
		ilitek,spi-mode = <0>;
		ilitek,byte-delay-us = <0>;
		ilitek,block-delay-us = <0>;
		ilitek,ubl-max-freq = <5000000>;
		ilitek,ubl-byte-delay-us = <20>;
		/* power capacitor discharging delay */
		ilitek,poweroff-discharging-us = <0>;
		
		ilitek,enable_sysinput_enabled;
	};
};

/* /home/dpi/qb5_8815/workspace/P4_1716/android/kernel/kmodule/input/touchscreen/ilitek/ili9881x/dts/input-qc-tsp-ili9881x.a23.dtsi */
