&qupv3_se0_spi {
	num-cs = <3>;
};

&tsp_ilitek {
	ilitek,lcdid1-gpio = <&pm6125_gpios 2 0x0>;
	ilitek,lcdid2-gpio = <&pm6125_gpios 8 0x0>;
	ilitek,lcdid3-gpio = <&pm6125_gpios 9 0x0>;
	ilitek,lcdid = <0 5>;
	ilitek,lcdtype = <0 0 0 0 0 0x4b6250>;
	ilitek,fw_name = "", "", "", "", "", "tsp_ilitek/ili7807_a23.hex";

	ilitek,lcd_rst = "lcd_rst";
	ilitek,lcd_bl_en = "lcd_bl_en";
	ilitek,lcd_vddi = "lcd_vddi";
	ilitek,lcd_vsp = "lcd_vsp";
	ilitek,lcd_vsn = "lcd_vsn";

	ilitek,poweroff-discharging-us = <2000>;

	ilitek,area-size = <48 81 30>;
	ilitek,enable_settings_aot;
	ilitek,support_ear_detect_mode;
	ilitek,prox_lp_scan_enabled;
	ilitek,support_spay_gesture_mode;
};

&soc {
	ss_touch {
		compatible = "samsung,ss_touch";
		ss_touch,numbers = <1>;
	};
};
